---
import { Image as AstroImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata | null | undefined;
  alt?: string;
  class?: string;
  [key: string]: any;
}

const { src, alt = "", ...rest } = Astro.props;
---

{
  src &&
    (typeof src === "string" ? (
      <AstroImage src={src} alt={alt} inferSize={true} {...rest} />
    ) : (
      <AstroImage src={src} alt={alt} {...rest} />
    ))
}
