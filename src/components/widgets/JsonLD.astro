---
import generateJsonLd from "@/utils/jsonLd";
import config from ".astro/config.generated.json" with { type: "json" };

const { content } = Astro.props;
let {
  title = config.site.title,
  metaTitle = title,
  description = config.site.description,
  metaDescription = description,
  image = config.opengraph.image,
  taglineSeparator = " - ",
  disableTagline,
  canonical,
  lang,
  author = config.seo.author,
  structuredData,
} = content;
title =
  !disableTagline && metaTitle ? metaTitle : title ? title : config.site.title;
const alternateLangs: any[] = [];
title += config.site.tagline ? taglineSeparator + config.site.tagline : "";
description = metaDescription ? metaDescription : description;
canonical = canonical ? canonical : Astro.url.href;
lang = config.settings.multilingual.defaultLanguage || "en";
image = image ? new URL(image, Astro.site ?? Astro.url.origin).href : "";
const jsonLdData = generateJsonLd(
  {
    ...content,
    ...structuredData,
    title,
    description,
    image,
    canonical,
    config,
    author,
    lang,
    alternateLangs,
  },
  Astro,
);
---

{
  content ? (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLdData, null, 2)}
    />
  ) : null
}
