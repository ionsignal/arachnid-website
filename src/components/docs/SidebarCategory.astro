---
import LucideIcon from "@/components/helpers/LucideIcon.astro";
import SidebarLink from "@/components/docs/SidebarLink.astro";
import type { DocActiveTrail, DocNavCategoryNode } from "@/types/docs";

interface Props {
  node: DocNavCategoryNode;
  activeTrail: DocActiveTrail;
}

const { node, activeTrail } = Astro.props;
const hasChildren = node.children.length > 0;
const isActiveTrail = node.id === activeTrail.categoryId;
const isOpen = isActiveTrail || !node.collapsed;
const contentId = `docs-cat-${node.id.replace(/\//g, "-")}`;
---

{
  hasChildren && (
    <li class="docs-sidebar-category">
      <button
        type="button"
        class:list={[
          "docs-sidebar-category-toggle hs-collapse-toggle",
          { open: isOpen },
        ]}
        data-hs-collapse={`#${contentId}`}
        aria-controls={contentId}
        aria-expanded={isOpen ? "true" : "false"}>
        <span class="docs-sidebar-category-label">
          {node.icon && (
            <LucideIcon
              icon={node.icon}
              class="docs-sidebar-category-icon"
              aria-hidden="true"
            />
          )}
          <span>{node.label}</span>
        </span>
        <LucideIcon
          icon="ChevronDown"
          class="docs-sidebar-category-chevron"
          aria-hidden="true"
        />
      </button>
      <ul
        id={contentId}
        class:list={[
          "docs-sidebar-category-content hs-collapse overflow-hidden transition-[height] duration-300",
          isOpen ? "open" : "hidden",
        ]}>
        {node.children.map((child) => (
          <SidebarLink node={child} activeTrail={activeTrail} />
        ))}
      </ul>
    </li>
  )
}
