{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ESNext",
    "allowJs": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "jsx": "react",
    "isolatedModules": true,
    "incremental": true,
    "types": ["node"],
    "paths": {
      ".astro/*": ["./.astro/*"],
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/shortcodes/*": ["./src/shortcodes/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "public", "scripts"]
}
